.ipynb_checkpoints/

# ============================================================
# Data and model files (keep out of git — use DVC or shared storage)
# ============================================================
data/
# datasets/

# Datasets folder handling: ignore all contents by default, but allow code and docs
Datasets/*
!Datasets/
!Datasets/**/
!Datasets/**/*.md
!Datasets/**/*.py
!Datasets/**/*.ipynb
!Datasets/**/*.txt


# Explicitly ignore common data formats if they are not already ignored
*.dcm
*.mha
*.nii
*.edf
*.pt
*.pth
*.h5
*.npy
*.npz

*.csv
*.hdf5
*.pkl
*.pickle
